---
layout: null
permalink: /search.json
sitemap: false
---
{% assign published_posts = site.posts | where_exp: "doc", "doc.status == 'published'" %}
{% assign published_research = site.research | where_exp: "doc", "doc.status == 'published'" %}
{% assign all_docs = published_posts | concat: published_research | sort: "date" | reverse %}
[
  {% for doc in all_docs %}
    {
      "title": {{ doc.title | jsonify }},
      "url": {{ doc.url | relative_url | jsonify }},
      "description": {{ doc.description | default: "" | strip_html | strip_newlines | jsonify }},
      "excerpt": {{ doc.excerpt | strip_html | strip_newlines | truncate: 220 | jsonify }},
      "categories": {{ doc.categories | jsonify }},
      "tags": {{ doc.tags | jsonify }},
      "lang": {{ doc.lang | default: site.lang | jsonify }},
      "type": {{ doc.doc_type | default: "post" | jsonify }},
      "series": {{ doc.series | default: "" | jsonify }},
      "date": {{ doc.date | date_to_xmlschema | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
