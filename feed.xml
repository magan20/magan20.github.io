---
layout: null
permalink: /feed.xml
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0">
  <channel>
    <title>{{ site.title | xml_escape }}</title>
    <description>{{ site.description | xml_escape }}</description>
    <link>{{ site.url }}</link>
    <language>{{ site.lang }}</language>
    {% assign published_posts = site.posts | where_exp: "doc", "doc.status == 'published'" %}
    {% assign published_research = site.research | where_exp: "doc", "doc.status == 'published'" %}
    {% assign feed_items = published_posts | concat: published_research | sort: "date" | reverse %}
    {% for doc in feed_items limit: 20 %}
      <item>
        <title>{{ doc.title | xml_escape }}</title>
        <description>{{ doc.description | default: doc.excerpt | strip_html | xml_escape }}</description>
        <link>{{ doc.url | absolute_url }}</link>
        <guid>{{ doc.url | absolute_url }}</guid>
        <pubDate>{{ doc.date | date_to_rfc822 }}</pubDate>
      </item>
    {% endfor %}
  </channel>
</rss>
